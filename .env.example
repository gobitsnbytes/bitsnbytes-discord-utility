# Notion
NOTION_TOKEN=
NOTION_FORK_REGISTRY_DB=

# Notion Extended Databases (Phase 2-3 features)
NOTION_TEAM_DB=          # Team members database
NOTION_EVENTS_DB=        # Events database
NOTION_REPORTS_DB=       # Reports database
NOTION_REMINDERS_DB=     # Smart reminders tracking database

# Fork Handbook
FORK_HANDBOOK_URL=https://www.notion.so/33949ed2fc33818ba073ffa2d815bf1a?v=33949ed2fc3380ccbfe2000c860aa29a&source=copy_link

# Discord Role IDs
STAFF_ROLE_ID=
FORK_LEAD_ROLE_ID=
EVERYONE_ROLE_ID=
EVENTS_CHANNEL_ID=

# Email (SMTP)
SMTP_HOST=                # SMTP server hostname
SMTP_PORT=587             # SMTP port (587 for STARTTLS)
SMTP_USER=                # SMTP username (full email)
SMTP_PASS=                # SMTP password
SMTP_FROM=                # From header (e.g., "Bits&Bytes <hello@gobitsnbytes.org>")

# Cal.com Integration
CALCOM_API_KEY=            # Cal.com API key (Settings → Developer → API Keys)
CALCOM_TEAM_SLUG=          # Cal.com team slug (e.g., bitsnbytes)
CALCOM_WEBHOOK_SECRET=     # Webhook signing secret (optional, for webhook mode)
WEBHOOK_PORT=3100          # Port for webhook receiver (optional)

